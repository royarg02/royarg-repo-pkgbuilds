_pkgname="dwm"
pkgname="$_pkgname-royarg-git"
pkgver=6.8.r5.44dbc68
pkgrel=1
pkgdesc="A modified version of the dynamic window manager for X."
arch=('i686' 'x86_64')
url="https://dwm.suckless.org"
license=('MIT')
depends=('libx11' 'libxft' 'libxinerama' 'freetype2')
makedepends=('git')
optdepends=('st: A simple virtual terminal emulator for X.')
provides=("$_pkgname")
conflicts=("$_pkgname" "$_pkgname-git")
source=(
  "git+https://git.suckless.org/dwm"
  0001-dwm-systray-20260322-44dbc68.diff
  0002-dwm-systray-statuscmd-20260322-44dbc68.diff
  0003-dwm-focusonclick-20200110-61bb8b2.diff
  0004-dwm-focusonclick-viewontag-20260322-44dbc68.diff
  0005-dwm-focusonclick-viewontag-barheightspacing-20260322-44dbc68.diff
  0006-dwm-cfacts-20200913-61bb8b2.diff
  0007-dwm-resizecorners-6.5.diff
  0008-dwm-tagmonfollow-20260322-44dbc68.diff
  0009-dwm-customxresources-20260322-44dbc68.diff
  0010-dwm-customsettings.diff
)
md5sums=('SKIP'
